# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Runtime config (auto-generated, may contain custom URLs) ──────────────────
# ── Runtime / generated config (may contain local URLs and secrets) ────────────────
config/app/settings.json

# ── Ollama model files (large binaries, re-pulled on first deploy) ────────────────
config/models/*
!config/models/.gitkeep

# ── Docker volumes / temp files ────────────────────────────────────────────────
*.log
*.tmp

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
